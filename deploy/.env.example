# rarebook.co.kr 맥미니 서버 환경변수 (이 파일을 .env 로 복사해 값 채우기)

# 로컬 PostgreSQL 접속 문자열
DATABASE_URL=postgresql://rarebooks:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/rarebooks

# Flask 세션 서명 키:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME_RANDOM_32_BYTES_HEX

# 관리자 /login 비밀번호
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Gemini(AI) 기능용 키 — 없으면 해당 기능만 비활성화
GOOGLE_API_KEY=
